# HelpTruth Backend - Miljøvariabler
# Kopier denne filen til .env og fyll inn verdiene
# ALDRI del .env-filen eller legg den i Git!

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL — bruk DATABASE_URL i produksjon fra Render)
DATABASE_URL=postgresql://helptruth:passord@localhost:5432/helptruth
# Eller individuelle variabler for lokal utvikling:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=helptruth
DB_USER=postgres
DB_PASSWORD=ditt_passord_her

# JWT (bruk en lang, tilfeldig streng — generer med: openssl rand -hex 64)
JWT_SECRET=bytt-meg-ut-med-noe-veldig-langt-og-hemmelig-123456

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# E-postverifisering (Gmail SMTP)
EMAIL_USER=din@gmail.com
EMAIL_PASS=gmail-app-passord
BACKEND_URL=https://helptruth-backend.onrender.com

# Cloudinary (bildeopplasting)
CLOUDINARY_CLOUD_NAME=ditt-cloud-name
CLOUDINARY_API_KEY=din-api-key
CLOUDINARY_API_SECRET=din-api-secret
